{
    "rewrites": [
        {
            "source": "/api/login",
            "destination": "/api/login.js"
        },
        {
            "source": "/api/bling/sync",
            "destination": "/api/bling/sync.js"
        }
    ],
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "X-Frame-Options",
                    "value": "DENY"
                },
                {
                    "key": "X-Content-Type-Options",
                    "value": "nosniff"
                },
                {
                    "key": "Referrer-Policy",
                    "value": "strict-origin-when-cross-origin"
                }
            ]
        }
    ]
}